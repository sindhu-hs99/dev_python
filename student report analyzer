#--------------------------------------------- Backend Python Code ----------------------------------------------
import pandas as pd
import numpy as np
from sklearn.preprocessing import LabelEncoder
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.ensemble import RandomForestRegressor

df = pd.read_csv("stud_datatset.csv")
#-------------- Calculating Avg_marks ------------------------
#slc_column = df.filter(like="_marks")
slc_column = ["math_marks","science_marks"]
df["avg_marks"] = df[slc_column].mean(axis=1).round(2)

#-------------- Calculating prfm_category ------------------
prfm_cond = [
    (df["avg_marks"] >= 90),
    (df["avg_marks"] >= 80) & (df["avg_marks"] <= 89),
    (df["avg_marks"] >= 70) & (df["avg_marks"] <= 79)
]
prfm_res = ["Excellent","Good","Average"]
df["prfm_category"] = np.select(prfm_cond,prfm_res, default="Poor")

#--------------- Calculating attnd_category ---------------------
attnd_cond = [
    (df["attendance"]>=95),
    (df["attendance"]>=85) & (df["attendance"]<=94)
]
attnd_res = ["Excellent", "Good"]
df["attnd_category"] = np.select(attnd_cond, attnd_res, default="Need Improvement")

#------------------ Writing to the CSV file ---------------------
df["total_marks"] = df["math_marks"] + df["science_marks"]
df.to_csv("stud_datatset.csv",index=False)

count = df["student_id"].nunique()
total = df.groupby(["student_id","name"]).sum(numeric_only=True).reset_index()

a = total.sort_values(["total_marks"],ascending=False).reset_index()
b = total.sort_values(["math_marks"],ascending=False).reset_index()
c = total.sort_values(["attendance"],ascending=True).reset_index()
topper = a.iloc[0]
sec_top = b.iloc[1]
low_attnd = c.iloc[0]

print(f'''
Total student count : {count}
Topper of the class : {topper["name"]} is the topper with marks {topper["total_marks"]} marks.
Second topper in the maths : {sec_top["name"]} is the 2nd topper in maths with {sec_top["math_marks"]} marks.
Lowest attendance : {low_attnd["name"]} is having lowest attandance in class {low_attnd["attendance"]}.
''')

#----------------------- Step 5: Train Model ---------------------------------
df["nxt_math"] = df.groupby("student_id")["math_marks"].shift(-1)
df["nxt_science"] = df.groupby("student_id")["science_marks"].shift(-1)

df_clean = df.dropna(subset=["nxt_math","nxt_science"])

x = df_clean[["attendance","math_marks","science_marks"]]
y = df_clean[["nxt_math","nxt_science"]]

#------------- Train the model
x_train,x_test, y_train, y_test = train_test_split(x,y, test_size=0.2,random_state=42)

model = RandomForestRegressor(random_state=42)
model.fit(x_train,y_train)

#----------------------- Step 6: Test Model ----------------------------------
test_input = pd.DataFrame([[94,91,91]],columns=["attendance","math_marks","science_marks"])
test_pred = model.predict(test_input)

print(f'''
-----------------Step 6: Evaluation ------------------------------
If attendance is 94, estimated maths mark is {test_pred[0][0]:.0f}
IF attendance is 94, estimated science mark is {test_pred[0][1]:.0f}
''')


# --------------------------- Student Report Function ------------------------------
def student_report(student_id):
    id = student_id

    data = df[df["student_id"]==id]

    if data.empty:
        return "Student id not found",None,None
    elif len(data) < 2:
        return "Insufficient Data.",None,None
    else:
        latest_data = {
            "student_name": f"{data["name"].iloc[-1]}",
            "student_id"  : f"{data["student_id"].iloc[-1]}",
            "Attendance"  : f"{data["attendance"].iloc[-1]}",
            "latest_math" : f"{data["math_marks"].iloc[-1]}",
            "latest_science" : f"{data["science_marks"].iloc[-1]}"
        }

        input_data = pd.DataFrame([[
            latest_data["Attendance"],latest_data["latest_math"],latest_data["latest_science"]]],
                                  columns=["attendance","math_marks","science_marks"])
        #input_data = pd.DataFrame([[94]],columns=["attendance"])
        pred_marks = model.predict(input_data)

        predicted_data = {
            "student_name" : f"{data["name"].iloc[-1]}",
            "student_id"   : f"{data["student_id"].iloc[-1]}",
            "predicted_math_marks" : f"{pred_marks[0][0]:.0f}",
            "predicted_science_marks" : f"{pred_marks[0][1]:.0f}"
        }
        print("Latest Data", latest_data)
        print("Predicted Data", predicted_data)
        #return "Success", latest_data,predicted_data
student_report(106)





