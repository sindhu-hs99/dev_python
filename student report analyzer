def student_btn():
    try:
        id = int(stud_textbox.get())
    except ValueError:
        messagebox.showwarning("warning","Please enter the valid numeric number...")
        return

    if not id:
        messagebox.showwarning("warning","Please enter the student id")

    status, latest, predict = student_ml.student_report(id)

    if status == "Student id not found":
        messagebox.showwarning("warning","Student_id not found")
    elif status == "Insufficient Data.":
        messagebox.showwarning("warning", "Insufficient Data")
    elif status == "Success":
        result_msg =(
            f"Student report analyzer\n"
            f"---------------------------------------\n"
            f"Student Name: {latest["student_name"]}\n"
            f"Student id  : {latest["student_id"]}\n"
            f"Attendance  : {latest["Attendance"]}\n"
            f"Latest_math_marks : {latest["latest_math"]}\n"
            f"Latest_science_marks : {latest["latest_science"]}\n"
            f"----------- Predicted Data --------------------\n"
            f"Predicted math marks : {predict["predicted_math_marks"]}\n"
            f"Predicted science marks : {predict["predicted_science_marks"]}\n"
        )
        messagebox.showinfo("Success",result_msg)
    
